# ── 이메일 알림 설정 ─────────────────────────────────────────
# 사용하려면 이 파일을 .env 로 복사 후 값을 채우세요

EMAIL_ENABLED=true

# Gmail 사용 시: 구글 계정 > 보안 > 앱 비밀번호 생성
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# 쉼표로 여러 수신자 지정 가능
ALERT_RECIPIENTS=gyeongwon.jo@day1company.co.kr
